FROM node:22-alpine AS frontend

WORKDIR /build/frontend
COPY frontend/package.json frontend/package-lock.json frontend/.npmrc ./
RUN npm ci
COPY frontend/ .
RUN npx vite build

FROM golang:1.25-alpine AS builder

RUN apk add --no-cache gcc musl-dev

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
COPY --from=frontend /build/frontend/dist /build/frontend/dist

RUN CGO_ENABLED=1 go build -ldflags "-X main.BuildDate=$(date -u +%Y-%m-%dT%H:%M:%SZ)" -o claworc .

FROM alpine:3.20

# nodejs/npm are needed for the `claude` CLI (Claude Code), which the
# orchestrator uses to log into and refresh a shared Claude subscription
# (anthropic-oauth providers). See docs/virtual-keys.md.
RUN apk add --no-cache ca-certificates sqlite-libs nodejs npm \
    && npm install -g @anthropic-ai/claude-code \
    && npm cache clean --force

WORKDIR /app

COPY --from=builder /build/claworc /app/claworc

EXPOSE 8000

ENTRYPOINT ["/app/claworc"]
